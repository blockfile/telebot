QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/your-key/
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789
# Required for live trade tracking (market cap / buyers / dev sells).
# Create at pumpportal.fun and fund its wallet with at least 0.02 SOL.
PUMPPORTAL_API_KEY=your-pumpportal-api-key
# Optional — only used when config.json "gmgn.enabled" is true (default: false).
# Adds GMGN security + smart-money/KOL data to alert cards. Get a key at gmgn.ai.
GMGN_API_KEY=your-gmgn-api-key
